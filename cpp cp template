string multiply(string num1, string num2) {
    if (num1 == "0" || num2 == "0")
        return "0";

    int n = num1.size();
    int m = num2.size();

    vector<int> result(n + m, 0);

    for (int i = n - 1; i >= 0; i--) {
        for (int j = m - 1; j >= 0; j--) {
            int mul = (num1[i] - '0') * (num2[j] - '0');
            int sum = mul + result[i + j + 1];

            result[i + j + 1] = sum % 10;
            result[i + j] += sum / 10;
        }
    }

    string ans;
    int i = 0;
    while (i < result.size() && result[i] == 0)
        i++;

    while (i < result.size())
        ans.push_back(result[i++] + '0');

    return ans.empty() ? "0" : ans;
}




long long binpow(long long a, long long b, long long mod) {
    a %= mod;
    long long res = 1;

    while (b > 0) {
        if (b & 1)
            res = (res * a) % mod;
        a = (a * a) % mod;
        b >>= 1;
    }

    return res;
}






int spf[N + 1];

void sieve() {
    for (int i = 0; i <= N; i++)
        spf[i] = i;

    for (int i = 2; i * i <= N; i++) {
        if (spf[i] == i) { // i is prime
            for (int j = i * i; j <= N; j += i) {
                if (spf[j] == j)
                    spf[j] = i;
            }
        }
    }
}







vector<pair<int,int>> factorize(int n) {
    vector<pair<int,int>> factors;

    while (n > 1) {
        int p = spf[n];
        int cnt = 0;

        while (n % p == 0) {
            n /= p;
            cnt++;
        }

        factors.push_back({p, cnt});
    }

    return factors;
}




vector<bool> isPrime(N + 1, true);

void sieve() {
    isPrime[0] = isPrime[1] = false;

    for (int i = 2; i * i <= N; i++) {
        if (isPrime[i]) {
            for (int j = i * i; j <= N; j += i)
                isPrime[j] = false;
        }
    }
}









